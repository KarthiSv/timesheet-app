# ─── Supabase (optional) ──────────────────────────────────────────────────────
# Enables shared user management across all browsers / devices.
# Without these the app falls back to browser-local storage (single-device only).
#
# How to get these values:
#   1. Create a free project at https://supabase.com
#   2. Go to Project Settings → API
#   3. Copy "Project URL" and "anon public" key
#
# For local dev: copy this file to .env.local and fill in your values
# For Vercel:    add these in Settings → Environment Variables
#
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Sign-In (optional) ────────────────────────────────────────────────
# Shows a "Sign in with Google" button on the login screen.
#
# How to get your Client ID:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID → Web application
#   3. Under "Authorised JavaScript origins" add your site URL, e.g.:
#        https://timesheet-app-nine-sable.vercel.app
#        http://localhost:5173   (for local dev)
#   4. Copy the Client ID (ends in .apps.googleusercontent.com)
#
VITE_GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnop.apps.googleusercontent.com
